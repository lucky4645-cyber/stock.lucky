name: Stock Sync Bot

on:
  schedule:
    - cron: '*/15 * * * *'  # Dar 15 minute-ae auto-run thase
  workflow_dispatch:      # Tu manually pan chalu kari shakish

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'

      - name: Install Dependencies
        run: pip install -r requirements.txt

      - name: Run Bot
        run: python bot.py

